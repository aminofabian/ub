# Copy to backend/.env (gitignored) or export in your process manager. Gradle bootRun
# reads backend/.env and passes each line to the JVM. See application.properties for defaults.

# --- Tenancy ---
APP_TENANCY_SLUG_DOMAIN_SUFFIX=localhost
APP_TENANCY_PLATFORM_HOSTS=

# --- Auth / verify UI (no inbox) ---
APP_AUTH_RETURN_VERIFICATION_LINK=false

# --- Public URLs ---
APP_PUBLIC_FRONTEND_BASE_URL=http://localhost:3000
# APP_PUBLIC_EMAIL_VERIFICATION_URL_PREFIX=
# APP_PUBLIC_PASSWORD_RESET_URL_PREFIX=
API_PUBLIC_BASE_URL=http://localhost:5050

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_EXTRA_ORIGIN_PATTERNS=

# --- Resend ---
RESEND_API_KEY=
RESEND_FROM=
RESEND_DOMAIN=

# --- Mailgun (after Resend); private key also accepts API_KEY ---
MAILGUN_FROM=
MAILGUN_REGION=us
MAILGUN_DOMAIN=
MAILGUN_PRIVATE_API_KEY=
# API_KEY=
MAILGUN_PUBLIC_VALIDATION_KEY=
MAILGUN_WEBHOOK_SIGNING_KEY=

# --- Cloudinary ---
# CLOUDINARY_URL=
APP_MEDIA_CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- M-Pesa STK simulate webhook ---
MPESA_STK_SIMULATE_SECRET=

# --- Optional overrides (relaxed binding) ---
# SERVER_PORT=
# SPRING_DATASOURCE_URL=
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=
# APP_JWT_SECRET=
# APP_JWT_ACCESS_TTL_MINUTES=
# APP_JWT_REFRESH_TTL_DAYS=
# APP_SECURITY_TEST_AUTH_ENABLED=
# APP_AUTH_PASSWORD_RESET_TTL_HOURS=
# APP_AUTH_SELF_SIGNUP_ENABLED=
# APP_AUTH_SIGNUP_ROLE_KEY=
# APP_AUTH_EMAIL_VERIFICATION_REQUIRED=
# APP_AUTH_EMAIL_VERIFICATION_TTL_HOURS=
# APP_SECURITY_LOGIN_RATE_LIMIT_PER_MINUTE=
# APP_SECURITY_PUBLIC_STOREFRONT_RATE_LIMIT_PER_MINUTE=
# APP_CREDITS_REMINDERS_ENABLED=
# APP_CREDITS_REMINDERS_CRON=
# APP_FINANCE_RECURRING_EXPENSES_ENABLED=
# APP_FINANCE_RECURRING_EXPENSES_CRON=
# SPRING_JPA_SHOW_SQL=
# SPRING_FLYWAY_BASELINE_ON_MIGRATE=
