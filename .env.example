# Copy to backend/.env (gitignored) or export in your process manager. Gradle bootRun
# reads backend/.env and passes each line to the JVM. See application.properties for defaults.

# --- Tenancy ---
APP_TENANCY_SLUG_DOMAIN_SUFFIX=localhost
APP_TENANCY_PLATFORM_HOSTS=

# --- Auth / verify UI (no inbox) ---
APP_AUTH_RETURN_VERIFICATION_LINK=false

# HttpOnly refresh cookie (default on; tests disable via application-test.properties).
# With the Next.js BFF on palmart.co.ke → kiosk.zelisline.com, leave DOMAIN empty
# or set to the frontend apex (e.g. .palmart.co.ke). Do NOT set the Java API host
# (kiosk.zelisline.com) — the browser never talks to that host for REST.
# APP_AUTH_REFRESH_COOKIE_SECURE=true
# APP_AUTH_REFRESH_COOKIE_DOMAIN=.palmart.co.ke
# APP_JWT_ACCESS_TTL_MINUTES=30
# APP_SECURITY_REFRESH_RATE_LIMIT_PER_MINUTE=30

# --- Public URLs ---
APP_PUBLIC_FRONTEND_BASE_URL=http://localhost:3000
# APP_PUBLIC_EMAIL_VERIFICATION_URL_PREFIX=
# APP_PUBLIC_PASSWORD_RESET_URL_PREFIX=
API_PUBLIC_BASE_URL=http://localhost:5050

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_EXTRA_ORIGIN_PATTERNS=

# --- Resend ---
RESEND_API_KEY=
RESEND_FROM=
RESEND_DOMAIN=

# --- Mailgun (after Resend); private key also accepts API_KEY ---
MAILGUN_FROM=
MAILGUN_REGION=us
MAILGUN_DOMAIN=
MAILGUN_PRIVATE_API_KEY=
# API_KEY=
MAILGUN_PUBLIC_VALIDATION_KEY=
MAILGUN_WEBHOOK_SIGNING_KEY=

# --- Cloudinary ---
# CLOUDINARY_URL=
APP_MEDIA_CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Payment gateway credentials at rest (required in production; stable across restarts) ---
# Generate once: openssl rand -base64 32
# APP_PAYMENTS_ENCRYPTION_KEY=

# --- M-Pesa STK simulate webhook ---
MPESA_STK_SIMULATE_SECRET=

# --- Credit tab sale reminders (optional env fallbacks; configure per tenant in Customers → Credit tab reminders) ---
# APP_CREDIT_SALE_REMINDER_PAYMENT_URL=https://palmart.co.ke/shop/account
RAPIDAPI_KEY=
# DeepSeek product descriptions (falls back to RAPIDAPI_KEY when unset)
# RAPIDAPI_DEEPSEEK_KEY=
# RAPIDAPI_DEEPSEEK_HOST=deepseek-v31.p.rapidapi.com
# RAPIDAPI_DEEPSEEK_URL=https://deepseek-v31.p.rapidapi.com/
# RAPIDAPI_DEEPSEEK_MODEL=DeepSeek-V3-0324
# RAPIDAPI_WHATSAPP_HOST=whatsapp-osint.p.rapidapi.com
# RAPIDAPI_WHATSAPP_LOOKUP_URL=https://whatsapp-osint.p.rapidapi.com/bizos
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=1252977897893339
# WHATSAPP_META_GRAPH_VERSION=v25.0
# Meta webhook callback: {API_PUBLIC_BASE_URL}/webhooks/whatsapp (openssl rand -hex 16)
WHATSAPP_META_WEBHOOK_VERIFY_TOKEN=
# Meta app secret — validates X-Hub-Signature-256 on inbound webhook POSTs (recommended in production).
WHATSAPP_META_APP_SECRET=
# SMS_PROVIDER=none
# SMS_PROVIDER=africas_talking
# AFRICAS_TALKING_USERNAME=
# AFRICAS_TALKING_API_KEY=

# --- Database (local dev defaults; override in production) ---
MYSQL_PASSWORD=00870087Fab.#

# --- Auth / JWT (local dev default; MUST be changed in production) ---
APP_JWT_SECRET=dev-dev-dev-dev-dev-dev-dev-dev-dev-dev-dev-dev-dev-dev-dev-dev-dev-dev-dev-dev

# --- Mobile tenant App Store publish (optional; one-click builds from admin → Store app) ---
# GitHub PAT with repo + workflow scope — dispatches mobile-tenant-publish workflow.
# APP_MOBILE_PUBLISH_GITHUB_TOKEN=
# APP_MOBILE_PUBLISH_GITHUB_REPO=owner/palmart
# APP_MOBILE_PUBLISH_EVENT_TYPE=mobile-tenant-publish
# Shared with GitHub Actions secret MOBILE_PUBLISH_CALLBACK_SECRET (openssl rand -base64 32).
# APP_MOBILE_PUBLISH_CALLBACK_SECRET=
# Public API base URL — also set as GitHub secret API_PUBLIC_BASE_URL for build callbacks.
# WebSocket clients read the absolute wss:// URL from ticket mint responses.
API_PUBLIC_BASE_URL=https://kiosk.zelisline.com

# --- Redis (optional — speeds up ticket + rate-limit storage) ---
# Without Redis, WebSocket tickets fall back to the shared MySQL table
# `realtime_ws_tickets` (migration V129) so multi-instance deploys still work.
# REDIS_URL=redis://redis:6379

# --- Optional overrides (relaxed binding) ---
# SERVER_PORT=
# SPRING_DATASOURCE_URL=
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=
# APP_JWT_ACCESS_TTL_MINUTES=
# APP_JWT_REFRESH_TTL_DAYS=
# APP_SECURITY_TEST_AUTH_ENABLED=
# APP_AUTH_PASSWORD_RESET_TTL_HOURS=
# APP_AUTH_SELF_SIGNUP_ENABLED=
# APP_AUTH_SIGNUP_ROLE_KEY=
# APP_AUTH_EMAIL_VERIFICATION_REQUIRED=
# APP_AUTH_EMAIL_VERIFICATION_TTL_HOURS=
# APP_SECURITY_LOGIN_RATE_LIMIT_PER_MINUTE=
# APP_SECURITY_PUBLIC_STOREFRONT_RATE_LIMIT_PER_MINUTE=
# APP_CREDITS_REMINDERS_ENABLED=
# APP_CREDITS_REMINDERS_CRON=
# APP_FINANCE_RECURRING_EXPENSES_ENABLED=
# APP_FINANCE_RECURRING_EXPENSES_CRON=
# SPRING_JPA_SHOW_SQL=
# SPRING_FLYWAY_BASELINE_ON_MIGRATE=
