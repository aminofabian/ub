# Optional: copy keys your process manager should set (IDE run config, Docker, systemd).
# Spring reads these from the environment; it does not load this file automatically.

# Frontend origin for verify-email and password-reset links (no trailing slash).
# Should match the browser URL of the Next app (NEXT_PUBLIC_APP_BASE_URL).
APP_PUBLIC_FRONTEND_BASE_URL=http://localhost:3000

# Optional full URL prefixes (otherwise built from APP_PUBLIC_FRONTEND_BASE_URL):
# APP_PUBLIC_EMAIL_VERIFICATION_URL_PREFIX=http://localhost:3000/verify-email?token=
# APP_PUBLIC_PASSWORD_RESET_URL_PREFIX=http://localhost:3000/reset-password?token=

# Public API origin (parity with NEXT_PUBLIC_API_BASE_URL; reserved for future use).
API_PUBLIC_BASE_URL=http://localhost:5050

# Default {slug}.{suffix} hostname when creating a tenant without a custom domain (hostname only; e.g. localhost or app.example.com).
# APP_TENANCY_SLUG_DOMAIN_SUFFIX=localhost

# Comma-separated browser origins. If you set ONLY production URLs here, local Next.js (http://localhost:3000)
# and http://*.localhost:3000 will be blocked — sign-in will show “Cannot reach API”. Either omit this for
# local dev (application.properties defaults apply) or include every origin you use, e.g.:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://palmart.co.ke,https://www.palmart.co.ke
CORS_ALLOWED_ORIGINS=https://palmart.co.ke
# Optional extra wildcard patterns for tenant subdomains / third-party admin hosts (see SecurityConfig).
# CORS_EXTRA_ORIGIN_PATTERNS=https://*.palmart.co.ke,https://*.zelisline.com