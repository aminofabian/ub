# =============================================================================
# Palmart — Backend (Spring Boot) environment template
# =============================================================================
#
# HOW TO USE
# ---------
# Spring Boot does **not** load this file automatically. Typical setups:
#   - Copy values into **`backend/.env`** (gitignored; often loaded by Gradle /
#     IDE when running `bootRun`), or
#   - Export variables in your shell / Docker / systemd / PaaS dashboard.
# Defaults for many keys also live in `src/main/resources/application.properties`.
#
# RELATED
# -------
# Frontend base URL here should match the Next app’s `NEXT_PUBLIC_APP_BASE_URL`
# (`frontend/.env.example`). CORS must allow that origin for browser→API calls.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Links in outbound email (verify email, password reset)
# -----------------------------------------------------------------------------
# Must match the **browser** URL of the Next.js app (no trailing slash).
#
APP_PUBLIC_FRONTEND_BASE_URL=http://localhost:3000

# Optional overrides (full URL prefix including query param name your pages expect):
# APP_PUBLIC_EMAIL_VERIFICATION_URL_PREFIX=http://localhost:3000/verify-email?token=
# APP_PUBLIC_PASSWORD_RESET_URL_PREFIX=http://localhost:3000/reset-password?token=

# -----------------------------------------------------------------------------
# Public API URL (documentation / future use; parity with frontend API base)
# -----------------------------------------------------------------------------
API_PUBLIC_BASE_URL=http://localhost:5050

# -----------------------------------------------------------------------------
# Tenancy
# -----------------------------------------------------------------------------
# Hostname suffix for generated `{slug}.{suffix}` tenant URLs (hostname only).
# APP_TENANCY_SLUG_DOMAIN_SUFFIX=localhost

# -----------------------------------------------------------------------------
# CORS (browser → API)
# -----------------------------------------------------------------------------
# Comma-separated allowed **origins** (scheme + host + port). If you set ONLY
# production URLs, local Next (`http://localhost:3000`) will be blocked and
# sign-in fails with opaque network errors.
#
# Local dev: either omit (see application.properties defaults) or include e.g.:
#   http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000
#
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Extra wildcard patterns (tenant subdomains, etc.) — see SecurityConfig.
# CORS_EXTRA_ORIGIN_PATTERNS=https://*.palmart.co.ke,https://*.zelisline.com

# -----------------------------------------------------------------------------
# Phase 15 — public storefront rate limit (optional override)
# -----------------------------------------------------------------------------
# GET /api/v1/public/** — max requests per minute per (client IP + business slug).
# Problem+JSON 429 with Retry-After: 60 when exceeded.
#
# APP_SECURITY_PUBLIC_STOREFRONT_RATE_LIMIT_PER_MINUTE=120

# -----------------------------------------------------------------------------
# Cloudinary (catalog / item images on the API)
# -----------------------------------------------------------------------------
# Put real credentials in **`backend/.env`** (gitignored), not committed samples.
# Startup reads `CLOUDINARY_URL` from env or `.env` next to the process cwd.
#
# Format (no trailing dot after cloud name):
# CLOUDINARY_URL=cloudinary://<API_KEY>:<API_SECRET>@<CLOUD_NAME>
#
# Or set the three parts separately:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
#
# Unset `APP_MEDIA_CLOUDINARY_ENABLED` to rely on auto-enable when URL parses;
# set `APP_MEDIA_CLOUDINARY_ENABLED=false` to force uploads off.
#
# CLOUDINARY_URL=

# -----------------------------------------------------------------------------
# Phase 5 — credits reminders + M-Pesa STK simulate webhook
# -----------------------------------------------------------------------------
# Optional shared secret for POST /webhooks/mpesa/stk/complete when testing wallet
# top-up simulation. When unset or blank the controller rejects every callback with
# 403. Set the same value in X-Mpesa-Simulate-Secret when calling that endpoint.
#
# MPESA_STK_SIMULATE_SECRET=
#
# Overdue reminder sweep (see application.properties; wire SMS/email later):
# APP_CREDITS_REMINDERS_ENABLED=true
# APP_CREDITS_REMINDERS_CRON=0 0 8 * * *
