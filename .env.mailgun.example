# Backend only — keep this file next to the Gradle project (backend/). Do not put Mailgun keys in the frontend.
# Spring maps these names into application.properties as app.mailgun.* (see application.properties).
#
# Copy to `.env.mailgun` (gitignored), fill in values, then expose them to the JVM that runs bootRun:
#   - IntelliJ / Cursor: Run Configuration → Environment variables → paste KEY=value pairs, or "EnvFile" plugin
#   - Terminal: export each variable before `./gradlew bootRun`
#
# Dashboard: https://app.mailgun.com/ → Sending → Domains.
#
# When MAILGUN_PRIVATE_API_KEY (or API_KEY) and MAILGUN_DOMAIN are set, the app sends via Mailgun's HTTP API (Unirest, same as Mailgun samples).
# Private API key (`key-…`) — REST API / sending
MAILGUN_PRIVATE_API_KEY=key-your-private-mailgun-key

# Alternative name used in Mailgun Java samples:
# API_KEY=key-your-private-mailgun-key

# Public validation key (`pubkey-…`) — Mailgun validation API
MAILGUN_PUBLIC_VALIDATION_KEY=pubkey-933c6ec8b4ca35d4337f07b29ffef0d4

# HTTP webhook signing key — verify Mailgun webhook requests (HMAC)
MAILGUN_WEBHOOK_SIGNING_KEY=a67bf3229fe0f6961de830efe5016a13

# api.mailgun.net (us) vs api.eu.mailgun.net (eu)
MAILGUN_REGION=us

# Sender domain exactly as in Mailgun (e.g. mg.example.com or your verified domain)
MAILGUN_DOMAIN=palmart.co.ke

# Optional From (must match Mailgun). Example sandbox: Mailgun Sandbox <postmaster@palmart.co.ke>
MAILGUN_FROM=

# --- Optional: real SMTP (enables JavaMailSender → actual delivery instead of console logs) ---
# 1) Set the variables below (Mailgun: Sending → Domain → SMTP credentials).
# 2) Run with profile smtp, e.g. SPRING_PROFILES_ACTIVE=smtp ./gradlew bootRun
#    (or add to your IDE run config). See application-smtp.properties.
# US: smtp.mailgun.org — EU: smtp.eu.mailgun.net
MAILGUN_SMTP_HOST=
MAILGUN_SMTP_PORT=587
MAILGUN_SMTP_LOGIN=
MAILGUN_SMTP_PASSWORD=
